# Always install devDependencies — required for TypeScript compilation on Render
# Render sets NODE_ENV=production which causes pnpm to skip devDeps by default
production=false

# Hoist all @prisma/* packages to top-level node_modules.
# Prisma v7 splits its runtime into sub-packages (@prisma/client-runtime-utils etc.)
# that the generated client requires via require(). pnpm's strict isolation prevents
# the generated code from finding sibling packages without this hoist.
public-hoist-pattern[]=@prisma/*
