# Server
NODE_ENV=development
SERVER_PORT=5000

# Frontend / Backend URLs
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=
BACKEND_LOCAL_URL=http://localhost:5000
BACKEND_SERVER_URL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mentalcare_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SESSION_SECRET=your_session_secret_key_here_min_32_chars
JWT_SESSION_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
