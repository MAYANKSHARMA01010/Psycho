# Server
SERVER_PORT=5000
NODE_ENV=development
# NODE_ENV=production
# For Production

# Frontend URLs
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=your_production_frontend_url_here

# Backend URLs
BACKEND_LOCAL_URL=http://localhost:5000
BACKEND_SERVER_URL=your_production_backend_url_here

# Redis URLs
REDIS_LOCAL_URL=redis://localhost:6379
REDIS_SERVER_URL=your_production_redis_url_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI_LOCAL=http://localhost:5001/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI_SERVER=your_production_backend_url_here/api/v1/auth/google/callback

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mentalcare_db

# JWT
JWT_SESSION_SECRET=your_session_secret_key_here_min_32_chars
JWT_SESSION_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary (file uploads — avatars, certificates, prescription PDFs)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=zenora

# Stripe (payments, subscriptions, refunds)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=inr
PLATFORM_COMMISSION_PERCENT=15

# SMTP (transactional email — verification, reset, session reminders)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_password_or_api_key
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Zenora
